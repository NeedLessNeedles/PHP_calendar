{% extends 'base.html.twig' %}

{% block title %}Local Events Calendar{% endblock %}

{% block body %}
{#<style>#}
{#    .example-wrapper { margin: 1em auto; max-width: 800px; width: 95%; font: 18px/1.5 sans-serif; }#}
{#    .example-wrapper code { background: #F5F5F5; padding: 2px 6px; }#}
{#</style>#}

<div class="container d-flex flex-column justify-content-center align-items-center
    min-hv-100 text-center border border-light rounded p-3 mt-4"
    style="max-width: 450px;"
>

    <p class="lead mb-4">
        Welcome to the local events calendar application.
    </p>

    {% if app.user %}
        <div class="mt-2">
            <a href="/event" class="btn btn-primary">
                Browse Events
            </a>
        </div>
    {% else %}
        <div class="d-flex gap-2">
            <a href="{{ path('app_login') }}" class="btn btn-success">
                Login
            </a>
            <a href="{{ path('app_register') }}" class="btn btn-outline-primary">
                Register
            </a>
        </div>
    {% endif %}

</div>
{% endblock %}
