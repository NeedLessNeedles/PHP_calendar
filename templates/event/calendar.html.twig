{#                <a href="{{ path('app_admin_users') }}" class="btn btn-primary">Admin panel</a>#}
{#            {% endif %}#}
{#        </div>#}
    </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}

    <script src="{{ asset('js/calendar.js') }}"></script>
{% endblock %}
