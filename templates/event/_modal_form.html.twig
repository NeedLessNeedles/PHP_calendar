<div class="modal fade" id="eventModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered justify-content-center" style="width: 480px; height: 350px;">
        <div class="modal-content auth-card p-3">
            <h1 class="h3 mb-1 font-weight-normal">Create new event</h1>
            {{ form_start(form, { attr: { id: 'create_event_form' } }) }}

            {{ form_row(form.title) }}
            {{ form_row(form.description) }}
            {{ form_row(form.location) }}
            {{ form_row(form.startDate) }}
            {{ form_row(form.endDate) }}
            {{ form_row(form.category) }}

            {{ form_end(form) }}

            <div class="d-flex flex-row justify-content-center align-items-center gap-2">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    Cancel
                </button>
                <button type="submit" form="create_event_form" class="btn btn-success">Save</button>
            </div>
        </div>
    </div>
</div>
