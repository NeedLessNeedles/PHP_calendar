<div class="modal fade" id="editModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered justify-content-center" style="width: 480px; height: 350px;">
        <div class="modal-content auth-card p-3">
            <h1 class="h3 mb-1 font-weight-normal">Edit event</h1>
            {{ form_start(editForm, { attr: { id: 'edit_event_form' } }) }}

            {{ form_row(editForm.title, {
                attr: { id: 'editEventTitle' }
            }) }}

            {{ form_row(editForm.description, {
                attr: { id: 'editEventDescription' }
            }) }}

            {{ form_row(editForm.location, {
                attr: { id: 'editEventLocation' }
            }) }}

            {{ form_row(editForm.startDate, {
                attr: { id: 'editEventStartDate' }
            }) }}

            {{ form_row(editForm.endDate, {
                attr: { id: 'editEventEndDate' }
            }) }}

            {{ form_row(editForm.category, {
                attr: { id: 'editEventCategory' }
            }) }}

            {{ form_end(editForm) }}

            <div class="d-flex flex-row justify-content-center align-items-center gap-2">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    Cancel
                </button>
                <button type="submit" form="edit_event_form" class="btn btn-success">Save</button>
            </div>
        </div>
    </div>
</div>
