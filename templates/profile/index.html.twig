{% extends 'base.html.twig' %}

{% block title %}Profile{% endblock %}

{% block body %}
    <div class="container d-flex justify-content-center align-items-center mt-3">
        <div class="auth-card d-flex flex-column gap-1">
            <h1 class="h3 mb-2 font-weight-normal">User info</h1>
            <div>
                <label>Email:</label>
                <strong>{{ app.user.email }}</strong>
            </div>
            {% set roles = app.user.roles %}
            <div>
                <label>Role:</label>
                {% if 'ROLE_ADMIN' in roles %}
                    <strong>admin</strong>
                {% elseif 'ROLE_USER' in roles %}
                    <strong>user</strong>
                {% else %}
                    <strong>unknown</strong>
                {% endif %}
            </div>

            <div class="d-flex justify-content-center gap-2 mt-2 mb-2">
                <a href="{{ path('app_home') }}" class="btn btn-primary"> << Back</a>
                <button
                    class="btn btn-success"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#editProfileCollapse"
                >
                    Edit profile
                </button>
                <button
                    class="btn btn-warning"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#changePasswordCollapse"
                >
                    Change password
                </button>
            </div>

            <div id="profileCollapseGroup">
                <div class="collapse" id="editProfileCollapse" data-bs-parent="#profileCollapseGroup">
                    <div class="card card-body mb-3">
                        {{ form_start(emailForm) }}
                        {{ form_row(emailForm.email) }}
                        <div class="d-flex justify-content-center gap-2 mt-2">
                            <button class="btn btn-success" type="submit">
                                Save
                            </button>
                        </div>
                        {{ form_end(emailForm) }}
                    </div>
                </div>

                <div class="collapse" id="changePasswordCollapse" data-bs-parent="#profileCollapseGroup">
                    <div class="card card-body py-2">
                        {{ form_start(passwordForm) }}
                        {{ form_row(passwordForm.currentPassword) }}
                        {{ form_row(passwordForm.newPassword) }}
                        <div class="d-flex justify-content-center gap-2 mt-1">
                            <button class="btn btn-success" type="submit">
                                Save
                            </button>
                        </div>
                        {{ form_end(passwordForm) }}
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
