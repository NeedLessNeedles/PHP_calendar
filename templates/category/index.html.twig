{% extends 'base.html.twig' %}

{% block title %}Categories{% endblock %}

{% block body %}
    <div class="container d-flex justify-content-center align-items-center mt-3">
        <div class="auth-card d-flex flex-column gap-1" style="max-width: 800px;">
            <div class="container mt-3">
                <h2>Categories</h2>

                <table class="table">
                    <thead>
                    <tr>
                        <th>ID</th>
                        <th>Title</th>
                        <th>Created at</th>
                        <th>Updated at</th>
                        <th>Actions</th>
                    </tr>
                    </thead>

                    <tbody>
                    {% for category in categories %}
                        <tr>
                            <td>{{ category.id }}</td>
                            <td>{{ category.title }}</td>
                            <td>{{ category.createdAt|date('Y-m-d H:i') }}</td>
                            <td>{{ category.updatedAt|date('Y-m-d H:i') }}</td>
                            <td>
                                <a href="{{ path('app_category_show', {'id': category.id}) }}" class="btn btn-primary btn-sm">Show</a>
                                <a href="{{ path('app_category_edit', {'id': category.id}) }}" class="btn btn-warning btn-sm">Edit</a>
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
            <div class="d-flex justify-content-center gap-2 mt-2 mb-2">
                <a href="{{ path('app_admin') }}" class="btn btn-primary"> << Back</a>
            </div>
        </div>
    </div>
{% endblock %}
