{% extends 'base.html.twig' %}

{% block title %}Tags{% endblock %}

{% block body %}
    <div class="container d-flex justify-content-center align-items-center mt-3">
        <div class="auth-card d-flex flex-column gap-1" style="max-width: 900px;">
            <div class="container mt-3">
                <h2>Tags</h2>

                <table class="table">
                    <thead>
                    <tr>
                        <th>ID</th>
                        <th>Title</th>
                        <th>Actions</th>
                    </tr>
                    </thead>

                    <tbody>
                    {% for tag in tags %}
                        <tr>
                            <td>{{ tag.id }}</td>
                            <td>{{ tag.title }}</td>
                            <td>
                                <button
                                    class="btn btn-primary btn-sm edit-category-btn"
                                    data-id="{{ tag.id }}"
                                    data-title="{{ tag.title }}"
                                    data-bs-toggle="modal"
                                    data-bs-target="#editTagModal"
                                >
                                    Edit
                                </button>

                                <form
                                    method="post"
                                    action="{{ path('app_tag_delete', {'id': tag.id}) }}"
                                    style="display:inline;"
                                    onsubmit="return confirm('Delete tag?');"
                                >
                                    <input
                                        type="hidden"
                                        name="_token"
                                        value="{{ csrf_token('delete' ~ tag.id) }}"
                                    >

                                    <button type="submit" class="btn btn-danger btn-sm">
                                        Delete
                                    </button>
                                </form>
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
            <div class="d-flex justify-content-center gap-2 mt-2 mb-2">
                <button
                    class="btn btn-success"
                    type="button"
                    data-bs-toggle="modal"
                    data-bs-target="#tagCreateModal"
                >
                    Create new
                </button>
            </div>

            <div class="modal fade" id="tagCreateModal" tabindex="-1">
                <div class="modal-dialog modal-lg modal-dialog-centered justify-content-center" style="width: 480px; height: 350px;">
                    <div class="modal-content auth-card p-3">
                        <h1 class="h3 mb-1 font-weight-normal">Create new tag</h1>
                        <form method="post" action="{{ path('app_tag_new') }}" id="createTagForm">
                            <div class="mb-3">
                                <label class="form-label">Tag title</label>
                                <input type="text" name="title" class="form-control" required>
                            </div>
                        </form>

                        <div class="d-flex flex-row justify-content-center align-items-center gap-2">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                                Cancel
                            </button>
                            <button type="submit" form="createTagForm" class="btn btn-success">Create</button>
                        </div>
                    </div>
                </div>
            </div>

            <div class="modal fade" id="editTagModal" tabindex="-1">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content auth-card p-3">

                        <h4>Edit tag</h4>
                        <form id="editTagForm" method="post">
                            <input
                                type="hidden"
                                name="_token"
                                value="{{ csrf_token('tag_edit') }}"
                            >
                            <div class="mb-3">
                                <label class="form-label">
                                    Change the tag name
                                </label>
                                <input
                                    type="text"
                                    id="editTagTitle"
                                    name="title"
                                    class="form-control"
                                >
                            </div>
                            <div class="d-flex flex-row justify-content-center align-items-center gap-2">
                                <button
                                    type="button"
                                    class="btn btn-secondary"
                                    data-bs-dismiss="modal"
                                >
                                    Cancel
                                </button>
                                <button
                                    type="submit"
                                    class="btn btn-success"
                                >
                                    Save
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

        </div>
    </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('js/edit_tag.js') }}"></script>
{% endblock %}
